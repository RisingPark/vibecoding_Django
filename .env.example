# Django Secret Key
# SECURITY WARNING: Generate a new secret key for production!
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-replace-with-random-generated-key

# Debug Mode
# SECURITY WARNING: Never set DEBUG=True in production!
DEBUG=True

# Allowed Hosts
# In production, set this to your domain(s)
# Example: ALLOWED_HOSTS=example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Path to SQLite database file
DATABASE_NAME=db/memojjang.sqlite3

